# UbuntuInit — .gitignore

# ── 用户自定义配置（不提交到仓库）──────────────────────────────────────
config/custom.conf
config/*.local.conf

# ── 运行时生成文件 ──────────────────────────────────────────────────────
/var/log/ubuntu-init*.log
*.log

# ── 测试/临时文件 ──────────────────────────────────────────────────────
/tmp/
*.tmp
*.bak
*.swp
*~

# ── 游戏存档 ────────────────────────────────────────────────────────────
.snake_hs
.2048_best

# ── OS 生成文件 ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / 编辑器 ────────────────────────────────────────────────────────
.idea/
.vscode/
*.code-workspace
.project
.settings/
*.sublime-workspace

# ── ShellCheck 缓存 ─────────────────────────────────────────────────────
.shellcheck-cache/
